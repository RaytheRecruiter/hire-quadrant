{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "allowImportingTsExtensions": false,
    "noEmit": true
  },
  "include": ["tests/**/*.ts", "helpers/**/*.ts", "*.ts"]
}
