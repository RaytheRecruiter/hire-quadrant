{
  "name": "hirequadrant-qa",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Playwright QA suite mirroring docs/HireQuadrant-QA-Walkthrough.docx",
  "scripts": {
    "install-browsers": "playwright install --with-deps chromium firefox webkit",
    "test": "playwright test --project=chromium-desktop",
    "test:all-browsers": "playwright test",
    "test:headed": "playwright test --project=chromium-desktop --headed",
    "test:b": "playwright test partB --project=chromium-desktop",
    "test:c": "playwright test partC --project=chromium-desktop",
    "test:d": "playwright test partD --project=chromium-desktop",
    "test:e": "playwright test partE --project=chromium-desktop",
    "test:f": "playwright test partF --project=chromium-desktop",
    "test:smoke": "playwright test --project=chromium-desktop --grep @smoke",
    "report": "playwright show-report",
    "lighthouse": "node lighthouse-runner.mjs",
    "ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "lighthouse": "^12.2.1",
    "otplib": "^12.0.1",
    "typescript": "^5.5.0"
  }
}
