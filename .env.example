# HireQuadrant Environment Variables
# Copy this to .env and fill in actual values

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Google Analytics
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Error Tracking
VITE_SENTRY_DSN=https://key@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=production

# Mailchimp Newsletter
VITE_MAILCHIMP_ACTION_URL=https://hirequadrant.us10.list-manage.com/subscribe/post?u=...

# Formspree Contact Form
VITE_FORMSPREE_ID=your_formspree_id_here

# OAuth (Optional - for future implementation)
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GITHUB_OAUTH_CLIENT_ID=your_github_client_id
VITE_LINKEDIN_OAUTH_CLIENT_ID=your_linkedin_client_id

# Stripe (Optional - for future subscription features)
VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxx

# Mapbox (mile-radius search, geocoding) — public token, protect via URL
# restrictions in the Mapbox dashboard rather than relying on secrecy.
VITE_MAPBOX_TOKEN=pk.eyJ1...

# API Keys (for server-side, if needed)
# SENDGRID_API_KEY=your_sendgrid_key
# INTERCOM_ACCESS_TOKEN=your_intercom_token
